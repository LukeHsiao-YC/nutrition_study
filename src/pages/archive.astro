---
import { getCollection } from 'astro:content';
const allArticles = await getCollection('articles');
const base = import.meta.env.BASE_URL;

const sortedArticles = allArticles.sort((a, b) => 
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const groupedArticles = {};
sortedArticles.forEach(article => {
  const date = new Date(article.data.pubDate);
  const monthYear = `${date.getFullYear()}年${date.getMonth() + 1}月`;
  if (!groupedArticles[monthYear]) {
    groupedArticles[monthYear] = [];
  }
  groupedArticles[monthYear].push(article);
});

function getCategoryStyle(category) {
  switch(category) {
    case '兒童肥胖': return 'background: #feebc8; color: #dd6b20;'; 
    case '營養衛教介入': return 'background: #c6f6d5; color: #38a169;'; 
    case '社區營養': return 'background: #e6fffa; color: #319795;'; 
    case '營養流行病學': return 'background: #faf5ff; color: #805ad5;'; 
    case '營養評估': return 'background: #ebf8ff; color: #3182ce;'; 
    default: return 'background: #edf2f7; color: #4a5568;'; 
  }
}
---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>歷史文獻庫</title>
    <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
  </head>
  <body style="max-width: 800px; margin: 0 auto; padding: 20px; font-family: sans-serif;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 15px; margin-bottom: 20px;">
      <div>
        <a href={base} style="color: #666; text-decoration: none;">← 返回首頁</a>
        <h1 style="margin-top: 10px; margin-bottom: 5px;">歷史文獻庫</h1>
        <p style="color: #666; margin-top: 0;">這裡收錄了所有過去抓取過的醫學與營養期刊文獻。</p>
      </div>

      <div style="display:flex; gap:10px; align-items:center;">
        <a href={`${base}deepread`} style="padding: 8px 16px; background: #2c5282; color: white; text-decoration: none; border-radius: 4px; white-space: nowrap;">深讀庫</a>
        <button id="filter-starred" style="padding: 6px 12px; background: #fff3c4; border: 1px solid #ecc94b; color: #b7791f; border-radius: 4px; cursor: pointer; font-size: 0.9rem; font-weight: bold;">
          ⭐ 只看星號收藏
        </button>
      </div>
    </div>

    <div id="search" style="margin-bottom: 30px;"></div>

    {Object.keys(groupedArticles).map((monthYear) => (
      <div class="month-group" style="margin-bottom: 40px;">
        <h2 style="border-bottom: 2px solid #2c5282; padding-bottom: 5px; color: #2c5282;">{monthYear}</h2>
        <ul style="list-style: none; padding: 0;">
          {groupedArticles[monthYear].map((article) => {
            const articleId = article.data.title.replace(/\s+/g, '-').slice(0, 30);
            return (
              <li class="archive-item" style="margin-bottom: 15px; padding: 15px; background: #f8fafc; border-radius: 6px; border-left: 4px solid #4299e1; position: relative;">
                
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                  <div style="margin-bottom: 5px; width: 90%;">
                    <span style={`display: inline-block; font-size: 0.75rem; padding: 3px 8px; border-radius: 4px; font-weight: bold; margin-right: 8px; vertical-align: text-bottom; ${getCategoryStyle(article.data.category)}`}>
                      {article.data.category}
                    </span>
                    <a href={`${base}paper/${article.slug}`} style="text-decoration: none; color: #2b6cb0; font-weight: bold; font-size: 1.1rem; vertical-align: middle;">
                      {article.data.title}
                    </a>
                  </div>

                  <button 
                    class="star-btn" 
                    data-id={articleId}
                    style="background: none; border: none; font-size: 1.3rem; cursor: pointer; color: #ccc; padding: 0;"
                    title="標記為重要"
                  >
                    ★
                  </button>
                </div>

                <div style="font-size: 0.85rem; color: #718096; margin-bottom: 8px; margin-top: 8px;">
                  {article.data.journal} | 收錄於 {article.data.pubDate}
                </div>
                <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                  {article.data.tags.map((tag) => (
                    <a href={`${base}tags/${tag}`} style="font-size: 0.75rem; background: #e2e8f0; padding: 2px 6px; border-radius: 4px; color: #4a5568; text-decoration: none;">#{tag}</a>
                  ))}
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    <script>
      // 處理星號點擊與狀態綁定
      document.querySelectorAll('.star-btn').forEach(btn => {
        const id = btn.getAttribute('data-id');
        if (localStorage.getItem('star-' + id)) {
          btn.style.color = '#ecc94b';
          btn.classList.add('is-starred');
        }

        btn.addEventListener('click', () => {
          if (localStorage.getItem('star-' + id)) {
            localStorage.removeItem('star-' + id);
            btn.style.color = '#ccc';
            btn.classList.remove('is-starred');
          } else {
            localStorage.setItem('star-' + id, 'true');
            btn.style.color = '#ecc94b';
            btn.classList.add('is-starred');
          }
        });
      });

      // 處理只顯示星號文章的過濾器
      const filterBtn = document.getElementById('filter-starred');
      let isFilterActive = false;

      if (filterBtn) {
        filterBtn.addEventListener('click', () => {
          isFilterActive = !isFilterActive;
          const allListItems = document.querySelectorAll('.archive-item');
          
          if (isFilterActive) {
            filterBtn.style.background = '#ecc94b';
            filterBtn.style.color = '#fff';
            filterBtn.innerText = '⭐ 顯示全部';
            
            allListItems.forEach(li => {
              const starBtn = li.querySelector('.star-btn');
              if (starBtn && starBtn.classList.contains('is-starred')) {
                li.style.display = 'block';
              } else {
                li.style.display = 'none';
              }
            });
          } else {
            filterBtn.style.background = '#fff3c4';
            filterBtn.style.color = '#b7791f';
            filterBtn.innerText = '⭐ 只看星號收藏';
            
            allListItems.forEach(li => {
              li.style.display = 'block';
            });
          }
        });
      }
    </script>

    <!-- Pagefind 全站搜尋(索引由 build 後 pagefind 產生;dev 模式下不存在屬正常) -->
    <script is:inline src={`${base}pagefind/pagefind-ui.js`} onerror="var s=document.getElementById('search'); if(s) s.innerHTML='<p style=\'color:#a0aec0;font-size:0.85rem\'>搜尋需 build 後才可用(npm run build / 線上站)。</p>';"></script>
    <script is:inline define:vars={{ base }}>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.PagefindUI) {
          new PagefindUI({ element: '#search', bundlePath: base + 'pagefind/', showSubResults: true, pageSize: 8 });
        }
      });
    </script>
  </body>
</html>
