---
import { getCollection } from 'astro:content';
const allArticles = await getCollection('articles');

const sortedArticles = allArticles.sort((a, b) => 
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

const recentArticles = sortedArticles.filter(article => {
  const articleDate = new Date(article.data.pubDate);
  return articleDate >= sevenDaysAgo;
});

const allTags = [...new Set(allArticles.map((article) => article.data.tags).flat())];
---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <title>最新營養與兒童醫學文獻</title>
  </head>
  <body style="max-width: 800px; margin: 0 auto; padding: 20px; font-family: sans-serif;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <h1>最新文獻速報 (近七日)</h1>
      <a href="/archive" style="padding: 8px 16px; background: #2c5282; color: white; text-decoration: none; border-radius: 4px;">📂 歷史文獻庫</a>
    </div>

    <div style="margin-bottom: 30px; margin-top: 20px;">
      <h3>分類標籤：</h3>
      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        {allTags.map((tag) => (
          <a href={`/tags/${tag}`} style="padding: 5px 12px; background: #f0f4f8; border-radius: 20px; text-decoration: none; color: #2c5282; font-size: 0.9rem;">
            #{tag}
          </a>
        ))}
      </div>
    </div>

    {recentArticles.length === 0 ? (
      <p style="color: #666; padding: 20px; text-align: center; background: #f9f9f9; border-radius: 8px;">最近七天沒有新的文獻更新。</p>
    ) : (
      recentArticles.map(async (article) => {
        const { Content } = await article.render();
        const articleId = article.data.title.replace(/\s+/g, '-').slice(0, 30);
        
        return (
          <article style="border: 1px solid #ddd; margin-bottom: 30px; padding: 20px; border-radius: 8px; position: relative;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <h2 style="font-size: 1.2rem; margin-bottom: 10px; width: 85%;">{article.data.title}</h2>
              
              <button 
                class="star-btn" 
                data-id={articleId}
                style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #ccc;"
                title="標記為重要"
              >
                ★
              </button>
            </div>
            
            <div style="display: flex; gap: 8px; margin-bottom: 10px;">
              <span style="font-size: 0.8rem; background: #e2e8f0; padding: 2px 8px; border-radius: 4px; color: #2d3748; font-weight: bold;">{article.data.category}</span>
              {article.data.tags.map((tag) => (
                <span style="font-size: 0.8rem; background: #edf2f7; padding: 2px 8px; border-radius: 4px; color: #4a5568;">{tag}</span>
              ))}
            </div>

            <p style="color: #666; font-size: 0.9rem;">
              期刊名稱：{article.data.journal} | 收錄日期：{article.data.pubDate}
            </p>
            
            <div style="margin-top: 10px; margin-bottom: 15px;">
              <a href={article.data.link} target="_blank" style="color: blue; text-decoration: none; margin-right: 15px;">🔗 閱讀原文</a>
              
              <button 
                class="copy-btn"
                data-content={`【${article.data.title}】\n\n${article.body}`}
                style="background: #2b6cb0; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 0.85rem;"
              >
                📝 複製給 NotebookLM
              </button>
            </div>

            <div style="line-height: 1.6; margin-top: 15px; border-top: 1px solid #eee; padding-top: 15px;">
              <Content />
            </div>
          </article>
        )
      })
    )}

    <script>
      document.querySelectorAll('.star-btn').forEach(btn => {
        const id = btn.getAttribute('data-id');
        if (localStorage.getItem('star-' + id)) {
          btn.style.color = '#ecc94b';
        }

        btn.addEventListener('click', () => {
          if (localStorage.getItem('star-' + id)) {
            localStorage.removeItem('star-' + id);
            btn.style.color = '#ccc';
          } else {
            localStorage.setItem('star-' + id, 'true');
            btn.style.color = '#ecc94b';
          }
        });
      });

      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const content = e.target.getAttribute('data-content');
          navigator.clipboard.writeText(content).then(() => {
            const originalText = e.target.innerText;
            e.target.innerText = '已複製！請前往 NotebookLM 貼上';
            e.target.style.background = '#38a169';
            
            setTimeout(() => {
              e.target.innerText = originalText;
              e.target.style.background = '#2b6cb0';
            }, 3000);
          });
        });
      });
    </script>
  </body>
</html>
